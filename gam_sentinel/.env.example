# ---- Model ----
# Option A (codelab default): Gemini via Google AI Studio
GOOGLE_GENAI_USE_VERTEXAI=FALSE
GOOGLE_API_KEY=
MODEL=gemini-2.5-flash
# Option B: Claude via LiteLLM  ->  set MODEL=anthropic/claude-sonnet-4-6 and:
# ANTHROPIC_API_KEY=

# ---- OrbiAds MCP ----
ORBIADS_MCP_URL=https://orbiads.com/mcp
# Bearer token from the OrbiAds OAuth flow. Leave empty to use a local stdio MCP (Chemin B).
ORBIADS_MCP_TOKEN=

# ---- A2A server ----
A2A_PORT=10000
